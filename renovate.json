{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "ignoreTests": false,
  "packageRules": [
    {
      "matchDatasources": ["helm"],
      "separateMinorPatch": true
    },
    {
      "description": "Automerge low-risk container image updates after CI passes.",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest", "patch"],
      "automerge": true,
      "labels": ["renovate", "automerge"]
    },
    {
      "description": "Automerge patch-level Helm chart updates after CI passes.",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "labels": ["renovate", "helm", "automerge"]
    },
    {
      "description": "Keep kube-prometheus-stack updates manual because monitoring upgrades can pass CI but fail at runtime.",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["renovate", "helm", "manual-approval"]
    },
    {
      "description": "Require manual approval for higher-risk Helm chart changes.",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["minor", "major"],
      "dependencyDashboardApproval": true,
      "labels": ["renovate", "helm", "manual-approval"]
    }
  ],
  "flux": {
    "managerFilePatterns": ["/\\.yaml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/apps/.*/values\\.yaml$/", "/infrastructure/.*/values\\.yaml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>[^\\s]+)\\n.*?tag:\\s*['\"]?(?<currentValue>[^\\s'\"]+)['\"]?"
      ]
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
